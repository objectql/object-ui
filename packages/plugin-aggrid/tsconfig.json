{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "noImplicitAny": true,
    "noEmit": false,
    "declaration": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../components"
    },
    {
      "path": "../core"
    },
    {
      "path": "../data-objectstack"
    },
    {
      "path": "../fields"
    },
    {
      "path": "../react"
    },
    {
      "path": "../types"
    }
  ]
}
